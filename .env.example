# SuryaGrid AI — environment template (Phase 1.5)
# Copy to .env and fill in. Never commit real secrets (.env is gitignored).

# ---- Database ----
# Local (no server):   sqlite+aiosqlite:///./suryagrid.db
# Docker / production:  postgresql+asyncpg://suryagrid:suryagrid@postgres:5432/suryagrid
DATABASE_URL=postgresql+asyncpg://suryagrid:suryagrid@postgres:5432/suryagrid

# ---- Cache / rate limit ----
REDIS_URL=redis://redis:6379/0

# ---- Kaggle dataset ingestion (OPTIONAL) ----
# If unset, drop the CSV manually in backend/data/raw/kaggle/. Never commit kaggle.json.
KAGGLE_USERNAME=
KAGGLE_KEY=

# ---- Live weather provider ----
WEATHER_PROVIDER=open-meteo
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1/forecast

# ---- Frontend -> backend API base (baked into the client bundle at build time) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ---- DSM defaults (see docs/DSM_RULE_SOURCES.md) ----
DSM_DEFAULT_REGION=Karnataka
DSM_DEFAULT_RULE_PROFILE=kerc-solar

# ---- App ----
ENVIRONMENT=production
