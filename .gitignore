.playwright-mcp/

# Phase 1.7 ML artifacts — large and/or from licensed sources; NOT committed.
# Reproduce exactly with:
#   cd backend
#   python -m app.ml.build_ml_datasets --region bengaluru --data-mode real
#   python -m app.ml.train_all_agents  --region bengaluru --data-mode real
# Model cards (backend/models/metadata/*.json), the rules engine, the tariff JSON,
# and the build manifest ARE committed as the evidence/provenance of the real run.
backend/data/ml/*.parquet
# ...except the small OSM/ODbL substation catalog + grid features (24 KB / 21 KB).
# The substation-driven agent workflow needs these to run in the repo / deployment,
# and they are the committed provenance of the 344 real Bengaluru substations.
!backend/data/ml/bengaluru_substations_cleaned.parquet
!backend/data/ml/bengaluru_grid_features.parquet
backend/data/raw/
backend/models/trained/*.pkl
backend/models/trained/*.zip

# Stray local files (not project deliverables)
IMG-*.jpg
kill3000.ps1


# Processed Kaggle datasets (reproducible via app.data_pipeline.ingest_kaggle_*)
backend/data/processed/kaggle/*.parquet

# Terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/terraform.tfvars
infra/terraform/.terraform.lock.hcl
